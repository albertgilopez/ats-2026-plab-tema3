# Copy this file to .env and fill the values. NEVER commit the real .env.
# The .env file is gitignored. A committed key = penalty + immediate rotation.

# MongoDB Atlas connection string (course cluster). URL-encode special chars in the password.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/"

# OpenAI API key — provided by the instructor through a secure channel.
OPENAI_API_KEY="sk-..."

# Database / collection — your group's PRIVATE copy (see README §2.2 for the $merge step).
# DB_NAME = cinematch_<NIU_lider>  (replace with the NIU of one group member)
DB_NAME="cinematch_REPLACE_NIU"
COLLECTION_NAME="embedded_movies"

# Vector index name (you create it during the workshop — see README).
VECTOR_INDEX_NAME="vectorPlotIndex"

# Embedding model. MUST match the model used to precompute `plot_embedding`
# in embedded_movies (text-embedding-ada-002, 1536 dims). Matching the
# dimension is NOT enough — the model itself must match.
EMBED_MODEL="text-embedding-ada-002"

# Chat model for N2+ (RAG generation). gpt-4o-mini is cheap and enough.
CHAT_MODEL="gpt-4o-mini"
